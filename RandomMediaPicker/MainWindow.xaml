<Window
    x:Class="RandomMediaPicker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RandomMediaPicker">

  <Grid RequestedTheme="Dark" Background="{StaticResource AppBackdropBrush}" Padding="28" RowSpacing="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Style="{StaticResource SectionCardStyle}">
      <Grid RowSpacing="18">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Spacing="4">
            <TextBlock Text="Random Media Picker" FontSize="34" FontWeight="Bold" />
            <TextBlock Text="Rediscover a random image or video from any folder in a polished, distraction-free viewer." Foreground="{StaticResource AppTextMutedBrush}" TextWrapping="Wrap" />
          </StackPanel>
          <Border Grid.Column="1" Background="#267C3AED" BorderBrush="#557C3AED" BorderThickness="1" CornerRadius="16" Padding="14,10" VerticalAlignment="Center">
            <TextBlock Text="Shuffle your library" FontWeight="SemiBold" />
          </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox x:Name="FolderPathBox" Header="Current folder" PlaceholderText="Choose a folder to scan" IsReadOnly="True" AutomationProperties.Name="Current folder path" />
          <Button Grid.Column="1" Content="Browse…" Click="Browse_Click" ToolTipService.ToolTip="Choose a media folder" />
          <Button Grid.Column="2" Content="Add favorite" Click="AddFavorite_Click" />
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <ComboBox x:Name="FavoritesBox" Header="Favorite folders" DisplayMemberPath="DisplayName" SelectionChanged="FavoritesBox_SelectionChanged" />
          <Button Grid.Column="1" Content="Rename" Click="RenameFavorite_Click" />
          <Button Grid.Column="2" Content="Remove" Click="RemoveFavorite_Click" />
          <Button Grid.Column="3" Content="Settings" Click="Settings_Click" />
        </Grid>

        <Grid Grid.Row="3" ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Button x:Name="OpenButton" Content="Open Random Media" Click="OpenRandom_Click" Style="{StaticResource AccentButtonStyle}" Padding="18,10" />
          <Button Grid.Column="1" Content="Rescan folder" Click="Rescan_Click" ToolTipService.ToolTip="Clear the cached media index and scan the folder again" />
          <Button x:Name="CancelButton" Grid.Column="2" Content="Cancel scan" Click="Cancel_Click" IsEnabled="False" />
          <ProgressRing x:Name="BusyRing" Grid.Column="3" IsActive="False" Width="34" Height="34" />
          <TextBlock x:Name="ProgressText" Grid.Column="4" VerticalAlignment="Center" Foreground="{StaticResource AppTextMutedBrush}" />
        </Grid>
      </Grid>
    </Border>

    <InfoBar x:Name="StatusBar" Grid.Row="1" IsOpen="True" Severity="Informational" Title="Ready" Message="Choose a folder, then open a random image or video." />

    <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}" Padding="0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Padding="20,18" BorderBrush="{StaticResource AppCardStrokeBrush}" BorderThickness="0,0,0,1">
          <StackPanel Spacing="4">
            <TextBlock x:Name="MediaTitle" FontSize="22" FontWeight="SemiBold" Text="No media selected" TextTrimming="CharacterEllipsis" />
            <TextBlock Text="The selected file previews here when using the internal viewer." Foreground="{StaticResource AppTextMutedBrush}" />
          </StackPanel>
        </Border>
        <Grid Grid.Row="1" MinHeight="300" Background="#66070B14">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
            <TextBlock Text="✦" FontSize="54" HorizontalAlignment="Center" Foreground="{StaticResource AppAccentAltBrush}" />
            <TextBlock Text="Your next random favorite is waiting" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
          </StackPanel>
          <Image x:Name="ImageViewer" Stretch="Uniform" Visibility="Collapsed" />
          <MediaPlayerElement x:Name="VideoViewer" AreTransportControlsEnabled="True" Stretch="Uniform" Visibility="Collapsed" />
        </Grid>
        <Border Grid.Row="2" Padding="20,16" BorderBrush="{StaticResource AppCardStrokeBrush}" BorderThickness="0,1,0,0">
          <StackPanel Spacing="10">
            <TextBlock x:Name="MediaPathText" TextWrapping="Wrap" Foreground="{StaticResource AppTextMutedBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Content="Reveal in File Explorer" Click="Reveal_Click" />
              <Button Content="Open with default app" Click="OpenExternal_Click" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <TextBlock Grid.Row="3" Text="Uses Windows codecs and file associations. Hidden/system temp files and directory reparse points are skipped during scans." TextWrapping="Wrap" Foreground="{StaticResource AppTextMutedBrush}" />
  </Grid>
</Window>
